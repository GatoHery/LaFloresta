<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.myapplication.Navegation.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_pedidos"
            app:destination="@id/pedidosFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/pedidosFragment"
        android:name="com.example.myapplication.Navegation.PedidosFragment"
        android:label="Mis Pedidos"
        tools:layout="@layout/fragment_pedidos" />

    <fragment
        android:id="@+id/crearPedidoFragment"
        android:name="com.example.myapplication.Navegation.CrearPedidoFragment"
        android:label="Crear Pedido"
        tools:layout="@layout/fragment_crear_pedido" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.myapplication.Navegation.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

</navigation>
